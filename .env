# dir 是存储日志和数据的位置
dir=./logs
# MemTableLimit 是活动 MemTable 的近似字节上限，0 表示不按容量自动切换。
MemTableLimit=4096
# AutoCheckpoint 控制 MemTable 达到上限后是否自动切换并在后台刷盘。
AutoCheckpoint=true
# CompactionThreshold 是触发自动 Compaction 的 SSTable 数量，0 表示关闭自动 Compaction。
CompactionThreshold=10
# Retention 是日志保留时长，仅在 Compaction 时淘汰过期记录，0 表示永久保留。
Retention=144
# MaxSizeBytes 是 Compaction 后允许保留的近似数据量，0 表示不限制容量。
MaxSizeBytes=0
# BlockCacheBytes 是共享 SSTable Block Cache 容量，0 表示禁用。
BlockCacheBytes=67108864
# MaxLevels、LevelBaseSizeBytes、LevelSizeMultiplier 控制分层 Compaction。
MaxLevels=4
LevelBaseSizeBytes=67108864
LevelSizeMultiplier=10
# WALSyncPolicy 可选 interval 或 every-write；后者在每次写入返回前 fsync。
WALSyncPolicy=interval
WALSyncInterval=50ms
# Address
Address="0.0.0.0"
# Port
Port=9999